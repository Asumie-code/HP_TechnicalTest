{
    "templates": {
        "banner": "<style> .banner { background: #fff; border-radius: 16px; box-shadow: 0 1px 4px 1px rgba(33, 33, 33, 0.2); overflow: hidden; display: flex; align-items: stretch; height: 168px; max-height: 162px; font-family: Inter, sans-serif; } .banner__image-wrapper { width: 386px; min-width: 180px; border-radius: 16px 0 0 16px; flex-shrink: 0; overflow: hidden; } .banner__image { width: 100%; height: 100%; object-fit: cover; display: block; } .banner__text { padding: 25px 30px; } .banner__title { font-size: 24px; font-weight: 500; line-height: 32px; margin: 0 0 10px 0; color: #111827; max-height: 32px; max-width: 35ch; white-space: nowrap; } .banner__description { font-size: 16px; color: #6b7280; margin: 0 0 10px 0; line-height: 24px; overflow: hidden; max-width: 100ch; } .banner__button { color: #fff; background-color: #0278AB; border-radius: 8px; padding: 8px 20px; border: none; font-size: 16px; line-height: 20px; white-space: nowrap; cursor: pointer; } .banner__button:hover { background-color: #035C84; } .banner__button:active, .banner__button:focus-visible { background-color: #014667; cursor: pointer; outline: none; } </style> <div class=\"banner\"> <div class=\"banner__image-wrapper\"> <img src=\"\" alt=\"Offer image\" class=\"banner__image\" /> </div> <div class=\"banner__text\"> <p class=\"banner__title\">banner Tile Offer Title</p> <p class=\"banner__description\">banner tile offer description - Lorem ipsum dolor sit amet, consectetur...</p> <button class=\"banner__button\">Offer button</button> </div> </div>",
        "carousel": "<div class='carousel'> <style> .carousel { border-radius: 16px; box-shadow: 0 1px 4px 1px rgba(33, 33, 33, 0.2); padding: 30px; height: 534px; } .carousel__image { max-height: 96px; margin-bottom: 20px; } .carousel__text-wrapper {} .carousel__title { font-size: 32px; } .carousel__description { font-size: 20px; line-height: 28px; margin-bottom: 20px; } .carousel__button { color: #fff; background-color: #0278AB; border-radius: 8px; padding: 8px 20px; max-width: 200px; border: none; font-size: 16px; line-height: 20px; white-space: nowrap; cursor: pointer; } .carousel__button:hover { background-color: #035C84; } .carousel__button:active, .carousel__button:focus-visible { background-color: #014667; cursor: pointer; outline: none; } </style> <div class='carousel__image-wrapper'> <img src='{{image}}' class='carousel__image' title='Offer logo' alt='{{title}}' /> </div> <div class='carousel__text-wrapper'> <div class='carousel__title'>{{title}}</div> <div class='carousel__description'>{{description}}</div> <button title='CTA' class='carousel__button'>{{buttonText}}</button> </div> </div>",
        "SKU": "<style> .SKU { background: #fff; border-radius: 16px; box-shadow: 0 1px 4px 1px rgba(33, 33, 33, 0.2); overflow: hidden; display: flex; align-items: stretch; height: 188px; max-height: 188px; font-family: inter, sans-serif; } .SKU__image-wrapper { width: 282px; border-radius: 16px; min-width: 180px; flex-shrink: 0; overflow: hidden; } .SKU__image { width: 100%; height: 100%; object-fit: cover; display: block; } .SKU__text { padding: 16px 30px; } .SKU__title { font-size: 13px; font-weight: 500; line-height: 20px; margin: 0px 0px 2px 0px; color: #404040; max-height: 32px; max-width: 25ch; background-color: rgba(61, 255, 172, 0.32); white-space: nowrap; border-radius: 17px; padding: 3px 20px; display: inline-block; } .SKU__description { font-size: 16px; color: #6b7280; margin: 0px 0px 1px 0px; line-height: 24px; height: 48px; overflow: hidden; max-width: 38ch; } .SKU__button { background-color: #fff; color: #0278AB; border: 1px solid #0278AB; border-radius: 8px; padding: 7px 19px; max-width: 200px; font-size: 16px; line-height: 20px; white-space: nowrap; cursor: pointer; } .SKU__button:hover { background-color: rgba(2, 120, 171, 0.05); color: #035C84; border: 1px solid #035C84; } .SKU__button:active, .SKU__button:focus-visible { background-color: rgba(2, 120, 171, 0.1); cursor: pointer; outline: none; color: #014667; border: 1px solid #014667; } .SKU__price { font-family: inter, sans-serif; margin: 0px 0px 20px 0px; } </style> <div class='SKU'> <div class='SKU__image-wrapper'> <img src='{{image}}' alt='{{title}}' class='SKU__image' /> </div> <div class='SKU__text'> <p class='SKU__title'>{{title}}</p> <p class='SKU__description'>{{description}}</p> <div class='SKU__price'>{{price}}</div> <button class='SKU__button'>{{buttonText}}</button> </div> </div>",
        "small": "<style> .small { background: #fff; border-radius: 16px; box-shadow: 0 1px 4px 1px rgba(33, 33, 33, 0.2); overflow: hidden; display: flex; align-items: stretch; height: 188px; max-height: 188px; font-family: inter, sans-serif; } .small__image-wrapper { width: 282px; min-width: 180px; border-radius: 16px; flex-shrink: 0; overflow: hidden; } .small__image { width: 100%; height: 100%; object-fit: cover; display: block; } .small__text { padding: 20px 30px; } .small__title { font-size: 24px; font-weight: 500; line-height: 32px; margin: 0px 0px 10px 0px; color: #111827; max-height: 32px; max-width: 25ch; white-space: nowrap; } .small__description { font-size: 16px; color: #6b7280; margin: 0px 0px 20px 0px; line-height: 24px; height: 48px; overflow: hidden; max-width: 38ch; } .small__button { color: #fff; background-color: #0278AB; border-radius: 8px; padding: 8px 20px; max-width: 200px; border: none; font-size: 16px; line-height: 20px; white-space: nowrap; cursor: pointer; } .small__button:hover { background-color: #035C84; } .small__button:active, .small__button:focus-visible { background-color: #014667; cursor: pointer; outline: none; } </style> <div class='small'> <div class='small__image-wrapper'> <img src='{{image}}' alt='{{title}}' class='small__image' /> </div> <div class='small__text'> <p class='small__title'>{{title}}</p> <p class='small__description'>{{description}}</p> <div class='small__price'>{{price}}</div> <button class='small__button'>{{buttonText}}</button> </div> </div>",
        "footer": "<style> .carousel__button { color: #fff; background-color: #0278AB; border-radius: 8px; padding: 8px 20px; max-width: 200px; border: none; font-size: 16px; line-height: 20px; white-space: nowrap; cursor: pointer; } .carousel__button:hover { background-color: #035C84; } .carousel__button:active, .carousel__button:focus-visible { background-color: #014667; cursor: pointer; outline: none; } .footer { display: flex; align-items: center; justify-content: center; height: 60px; background-color: #fff; gap: 24px; border-top: 1px solid #000000; } </style> <div class=\"footer\"> <div>title</div> <div class=\"carousel__button\">Offer button</div> </div>"
